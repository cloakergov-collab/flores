# API Key da BlackCat Pay (painel administrativo → API)
# Enquanto este valor estiver vazio, o PIX roda em MODO DEMO
# (confirma o pagamento sozinho ~18s depois, só para testar o visual).

BLACKCAT_API_KEY=

# URL base da API BlackCat Pay (endpoints /sales/create-sale e /sales/{id}/status)
BLACKCAT_BASE_URL=https://api.blackcatpay.com.br/api

# URL de postback (webhook) que a BlackCat chama ao mudar o status da transação.
POSTBACK_URL=https://paraisodaflor.com/api/webhook

# Opcionais:
# PORT=8099
# PIX_EXPIRES_DAYS=1
